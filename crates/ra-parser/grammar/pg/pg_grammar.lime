    					n->indirection = check_indirection(C, yyscanner);

    					n->val = (selectStmt *) E;
    					n->location = LOC(B);
    					A = (Node *) n;
}

/* ----- plassign_target ----- */

plassign_target(A) ::= colId(B). {
