    					n->lateral = false;
    					n->ordinality = C;
    					n->is_rowsfrom = false;
    					n->functions = list_make1(list_make2(B, NIL));

    					A = (Node *) n;
}

func_table(A) ::= ROWS FROM LPAREN rowsfrom_list(E) RPAREN opt_ordinality(G). {
    RangeFunction *n = makeNode(RangeFunction);

    					n->lateral = false;
    					n->ordinality = G;
    					n->is_rowsfrom = true;
