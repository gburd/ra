onCommitOption(A) ::= ON COMMIT DROP. {
    A = ONCOMMIT_DROP;
}

onCommitOption(A) ::= ON COMMIT DELETE_P ROWS. {
    A = ONCOMMIT_DELETE_ROWS;
}

onCommitOption(A) ::= ON COMMIT PRESERVE ROWS. {
    A = ONCOMMIT_PRESERVE_ROWS;
}

onCommitOption(A) ::= . {
