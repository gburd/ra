    pg_yyget_extra(yyscanner)->parsetree = list_make1(C);
}

parse_toplevel(A) ::= MODE_PLPGSQL_EXPR pLpgSQL_Expr(C). {
    pg_yyget_extra(yyscanner)->parsetree =
    					list_make1(makeRawStmt(C, LOC(C)));
}

