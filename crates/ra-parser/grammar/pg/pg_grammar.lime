opt_verbose(A) ::= VERBOSE. {
    A = true;
}

opt_verbose(A) ::= . {
    A = false;
}

/* ----- opt_full ----- */

opt_full(A) ::= FULL. {
    A = true;
}

opt_full(A) ::= . {
    A = false;
}

/* ----- opt_freeze ----- */

opt_freeze(A) ::= FREEZE. {
    A = true;
}

opt_freeze(A) ::= . {
    A = false;
}

