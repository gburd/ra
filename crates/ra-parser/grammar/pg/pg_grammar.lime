reindex_target_relation(A) ::= INDEX. {
    A = REINDEX_OBJECT_INDEX;
}

reindex_target_relation(A) ::= TABLE. {
    A = REINDEX_OBJECT_TABLE;
}

/* ----- reindex_target_all ----- */

reindex_target_all(A) ::= SYSTEM_P. {
    A = REINDEX_OBJECT_SYSTEM;
}

reindex_target_all(A) ::= DATABASE. {
