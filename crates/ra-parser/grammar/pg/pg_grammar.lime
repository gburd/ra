    transactionStmt *n = makeNode(transactionStmt);

    					n->kind = TRANS_STMT_ROLLBACK;
    					n->options = NIL;
    					n->chain = D;
    					n->location = -1;
    					A = (Node *) n;
}

transactionStmt(A) ::= START TRANSACTION transaction_mode_list_or_empty(D). {
    transactionStmt *n = makeNode(transactionStmt);

    					n->kind = TRANS_STMT_START;
    					n->options = D;
    					n->location = -1;
    					A = (Node *) n;
}

