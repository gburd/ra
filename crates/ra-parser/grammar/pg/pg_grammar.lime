createCastStmt(A) ::= CREATE CAST LPAREN typename(E) AS typename(G) RPAREN WITH FUNCTION function_with_argtypes(K) cast_context(L). {
    createCastStmt *n = makeNode(createCastStmt);

    					n->sourcetype = E;
