/* -- BETWEEN ------------------------------------------------------- */
/* Expand to AND of GE and LE comparisons. */

expr(A) ::= expr(B) BETWEEN expr(C) AND expr(D). [BETWEEN]

%action_rust {
    /* Expand: expr BETWEEN low AND high => (expr >= low) AND (expr <= high) */
    let mut ge = ra_binop(ctx.user, 9, B.clone(), C);  /* GE */
    let mut le = ra_binop(ctx.user, 7, B.clone(), D);  /* LE */
    A = ra_binop(ctx.user, 10, ge, le);         /* AND */
}

expr(A) ::= expr(B) NOT BETWEEN expr(C) AND expr(D). [BETWEEN]

%action_rust {
    let mut lt = ra_binop(ctx.user, 6, B.clone(), C);  /* LT */
    let mut gt = ra_binop(ctx.user, 8, B.clone(), D);  /* GT */
    A = ra_binop(ctx.user, 11, lt, gt); /* OR: NOT BETWEEN = < low OR > high */
}

