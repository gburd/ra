delete_stmt(A) ::= DELETE FROM IDENT(T)
                    opt_using(U) opt_where(W) opt_returning(R).

%action_rust {
    A = ra_delete(ctx.user, T.text(), W, U, R);
}
delete_stmt(A) ::= DELETE FROM IDENT(T) AS IDENT
                    opt_using(U) opt_where(W) opt_returning(R).

%action_rust {
    A = ra_delete(ctx.user, T.text(), W, U, R);
}

opt_using(A) ::= .

%action_rust {
    A = Value::default();
}
opt_using(A) ::= USING from_list(B).
%action_rust {
    A = B;
}

/* -- Shared DML optional WHERE ------------------------------------- */

opt_where(A) ::= .

%action_rust {
    A = Value::default();
}
opt_where(A) ::= WHERE expr(B).
%action_rust {
    A = B;
}

/* -- MERGE --------------------------------------------------------- */

merge_stmt(A) ::= MERGE INTO IDENT(T) USING table_ref(S) ON expr(O)
                   merge_when_list(W) opt_returning(R).

%action_rust {
    A = ra_merge(ctx.user, T.text(), S, O, W, R);
}
merge_stmt(A) ::= MERGE INTO IDENT(T) AS IDENT USING table_ref(S) ON expr(O)
                   merge_when_list(W) opt_returning(R).

%action_rust {
    A = ra_merge(ctx.user, T.text(), S, O, W, R);
}
merge_stmt(A) ::= MERGE INTO IDENT(T) IDENT USING table_ref(S) ON expr(O)
                   merge_when_list(W) opt_returning(R).

%action_rust {
    A = ra_merge(ctx.user, T.text(), S, O, W, R);
}

merge_when_list(A) ::= merge_when(B).

%action_rust {
    A = ra_list_push(ctx.user, ra_list_new(ctx.user), B);
}
merge_when_list(A) ::= merge_when_list(L) merge_when(B).

%action_rust {
    A = ra_list_push(ctx.user, L, B);
}

opt_merge_and(A) ::= .

%action_rust {
    A = Value::default();
}
opt_merge_and(A) ::= AND expr(B).
%action_rust {
    A = B;
}

/* WHEN MATCHED (kind 0) */
merge_when(A) ::= WHEN MATCHED opt_merge_and(C) THEN UPDATE SET assignment_list(S).

%action_rust {
    A = ra_merge_when_update(ctx.user, 0, C, S);
}
merge_when(A) ::= WHEN MATCHED opt_merge_and(C) THEN DELETE.

%action_rust {
    A = ra_merge_when_delete(ctx.user, 0, C);
}
merge_when(A) ::= WHEN MATCHED opt_merge_and(C) THEN DO NOTHING.

%action_rust {
    A = ra_merge_when_nothing(ctx.user, 0, C);
}

/* WHEN NOT MATCHED [BY TARGET] (kind 1) */
merge_when(A) ::= WHEN NOT MATCHED opt_merge_and(C)
                   THEN INSERT LPAREN ident_list(CO) RPAREN VALUES LPAREN expr_list(V) RPAREN.

%action_rust {
    A = ra_merge_when_insert(ctx.user, 1, C, CO, V);
}
merge_when(A) ::= WHEN NOT MATCHED opt_merge_and(C)
                   THEN INSERT VALUES LPAREN expr_list(V) RPAREN.

%action_rust {
    A = ra_merge_when_insert(ctx.user, 1, C, Value::default(), V);
}
merge_when(A) ::= WHEN NOT MATCHED opt_merge_and(C) THEN DO NOTHING.

%action_rust {
    A = ra_merge_when_nothing(ctx.user, 1, C);
}

/* WHEN NOT MATCHED BY SOURCE|TARGET. SOURCE/TARGET arrive as IDENT;
 * ra_merge_kind_by maps "source" -> 2, anything else -> 1. The parser
 * is permissive about which action follows which side (UPDATE/DELETE
 * are only valid BY SOURCE; INSERT only BY TARGET) — invalid
 * combinations are a semantic, not syntactic, error. */
merge_when(A) ::= WHEN NOT MATCHED BY IDENT(D) opt_merge_and(C)
                   THEN UPDATE SET assignment_list(S).

%action_rust {
    A = ra_merge_when_update(ctx.user, ra_merge_kind_by(D.text()), C, S);
}
merge_when(A) ::= WHEN NOT MATCHED BY IDENT(D) opt_merge_and(C) THEN DELETE.

%action_rust {
    A = ra_merge_when_delete(ctx.user, ra_merge_kind_by(D.text()), C);
}
merge_when(A) ::= WHEN NOT MATCHED BY IDENT(D) opt_merge_and(C) THEN DO NOTHING.

%action_rust {
    A = ra_merge_when_nothing(ctx.user, ra_merge_kind_by(D.text()), C);
}
merge_when(A) ::= WHEN NOT MATCHED BY IDENT(D) opt_merge_and(C)
                   THEN INSERT LPAREN ident_list(CO) RPAREN VALUES LPAREN expr_list(V) RPAREN.

%action_rust {
    A = ra_merge_when_insert(ctx.user, ra_merge_kind_by(D.text()), C, CO, V);
}
merge_when(A) ::= WHEN NOT MATCHED BY IDENT(D) opt_merge_and(C)
                   THEN INSERT VALUES LPAREN expr_list(V) RPAREN.

%action_rust {
    A = ra_merge_when_insert(ctx.user, ra_merge_kind_by(D.text()), C, Value::default(), V);
}

/* -- GRAPH_TABLE (SQL/PGQ, SQL:2023 / PostgreSQL 19) --------------- */

graph_table_ref(A) ::= GRAPH_TABLE LPAREN IDENT(G) MATCH graph_pattern(P)
                        COLUMNS LPAREN target_list(C) RPAREN RPAREN.

%action_rust {
    A = ra_graph_table(ctx.user, Some(G.text()), P, C, None);
}
graph_table_ref(A) ::= GRAPH_TABLE LPAREN IDENT(G) MATCH graph_pattern(P)
                        COLUMNS LPAREN target_list(C) RPAREN RPAREN AS IDENT(AL).

%action_rust {
    A = ra_graph_table(ctx.user, Some(G.text()), P, C, Some(AL.text()));
}

graph_pattern(A) ::= graph_elem(B).

%action_rust {
    A = ra_list_push(ctx.user, ra_list_new(ctx.user), B);
}
graph_pattern(A) ::= graph_pattern(L) graph_elem(B).

%action_rust {
    A = ra_list_push(ctx.user, L, B);
}

/* vertices: ( ), (v), (v IS label), (IS label) */
graph_elem(A) ::= LPAREN RPAREN.

%action_rust {
    A = ra_graph_vertex(ctx.user, None, None);
}
graph_elem(A) ::= LPAREN IDENT(V) RPAREN.

%action_rust {
    A = ra_graph_vertex(ctx.user, Some(V.text()), None);
}
graph_elem(A) ::= LPAREN IDENT(V) IS IDENT(L) RPAREN.

%action_rust {
    A = ra_graph_vertex(ctx.user, Some(V.text()), Some(L.text()));
}
graph_elem(A) ::= LPAREN IS IDENT(L) RPAREN.

%action_rust {
    A = ra_graph_vertex(ctx.user, None, Some(L.text()));
}

/* edges: right -[..]-> (dir 0), undirected -[..]- (dir 2),
 *        left <-[..]- (dir 1) */
graph_elem(A) ::= MINUS LBRACKET RBRACKET ARROW.

%action_rust {
    A = ra_graph_edge(ctx.user, None, None, 0);
}
graph_elem(A) ::= MINUS LBRACKET IDENT(V) RBRACKET ARROW.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), None, 0);
}
graph_elem(A) ::= MINUS LBRACKET IDENT(V) IS IDENT(L) RBRACKET ARROW.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), Some(L.text()), 0);
}
graph_elem(A) ::= MINUS LBRACKET RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, None, None, 2);
}
graph_elem(A) ::= MINUS LBRACKET IDENT(V) RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), None, 2);
}
graph_elem(A) ::= MINUS LBRACKET IDENT(V) IS IDENT(L) RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), Some(L.text()), 2);
}
graph_elem(A) ::= LT MINUS LBRACKET RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, None, None, 1);
}
graph_elem(A) ::= LT MINUS LBRACKET IDENT(V) RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), None, 1);
}
graph_elem(A) ::= LT MINUS LBRACKET IDENT(V) IS IDENT(L) RBRACKET MINUS.

%action_rust {
    A = ra_graph_edge(ctx.user, Some(V.text()), Some(L.text()), 1);
}

/* ================================================================== */
/* Expression rules                                                    */
/* ================================================================== */

/* -- Atoms --------------------------------------------------------- */

expr(A) ::= IDENT(B).

%action_rust {
    A = ra_column(ctx.user, B.text());
}
expr(A) ::= IDENT(B) DOT IDENT(C).

%action_rust {
    A = ra_qualified_column(ctx.user, B.text(), C.text());
}
expr(A) ::= ICONST(B).

%action_rust {
    A = ra_const_int(ctx.user, B.int_val);
}
expr(A) ::= FCONST(B).

%action_rust {
    A = ra_const_float(ctx.user, B.float_val);
}
expr(A) ::= SCONST(B).

%action_rust {
    A = ra_const_str(ctx.user, B.text());
}
expr(A) ::= NULL_KW.

%action_rust {
    A = ra_const_null(ctx.user);
}
expr(A) ::= TRUE_KW.

%action_rust {
    A = ra_const_int(ctx.user, 1);
}
expr(A) ::= FALSE_KW.

%action_rust {
    A = ra_const_int(ctx.user, 0);
}

/* -- Binary operations --------------------------------------------- */

expr(A) ::= expr(B) PLUS expr(C).

%action_rust {
    A = ra_binop(ctx.user, 0, B, C);
}
expr(A) ::= expr(B) MINUS expr(C).

%action_rust {
    A = ra_binop(ctx.user, 1, B, C);
}
expr(A) ::= expr(B) STAR expr(C).

%action_rust {
    A = ra_binop(ctx.user, 2, B, C);
}
expr(A) ::= expr(B) SLASH expr(C).

%action_rust {
    A = ra_binop(ctx.user, 3, B, C);
}
expr(A) ::= expr(B) EQ expr(C).

%action_rust {
    A = ra_binop(ctx.user, 4, B, C);
}
expr(A) ::= expr(B) NE expr(C).

%action_rust {
    A = ra_binop(ctx.user, 5, B, C);
}
expr(A) ::= expr(B) LT expr(C).

%action_rust {
    A = ra_binop(ctx.user, 6, B, C);
}
expr(A) ::= expr(B) LE expr(C).

%action_rust {
    A = ra_binop(ctx.user, 7, B, C);
}
expr(A) ::= expr(B) GT expr(C).

%action_rust {
    A = ra_binop(ctx.user, 8, B, C);
}
expr(A) ::= expr(B) GE expr(C).

%action_rust {
    A = ra_binop(ctx.user, 9, B, C);
}
expr(A) ::= expr(B) AND expr(C).

%action_rust {
    A = ra_binop(ctx.user, 10, B, C);
}
expr(A) ::= expr(B) OR expr(C).

%action_rust {
