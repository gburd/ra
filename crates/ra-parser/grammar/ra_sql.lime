/* -- INSERT -------------------------------------------------------- */

insert_stmt(A) ::= INSERT INTO IDENT(T) opt_col_list(C)
                    insert_source(S) opt_on_conflict(O) opt_returning(R).

%action_rust {
    A = ra_insert(ctx.user, T.text(), C, S, O, R);
}

insert_source(A) ::= select_stmt(B).
%action_rust {
    A = B;
}
insert_source(A) ::= DEFAULT VALUES.

%action_rust {
    A = ra_default_values(ctx.user);
}

opt_col_list(A) ::= .

%action_rust {
    A = Value::default();
}
opt_col_list(A) ::= LPAREN ident_list(B) RPAREN.
%action_rust {
    A = B;
}

opt_on_conflict(A) ::= .

%action_rust {
    A = Value::default();
}
opt_on_conflict(A) ::= ON CONFLICT DO NOTHING.

%action_rust {
    A = ra_on_conflict_nothing(ctx.user);
}
opt_on_conflict(A) ::= ON CONFLICT LPAREN ident_list(T) RPAREN
                        DO UPDATE SET assignment_list(L).

%action_rust {
    A = ra_on_conflict_update(ctx.user, T, L);
}
opt_on_conflict(A) ::= ON CONFLICT LPAREN ident_list(T) RPAREN DO SELECT.

%action_rust {
    A = ra_on_conflict_select(ctx.user, T);
}
opt_on_conflict(A) ::= ON CONFLICT DO SELECT.

%action_rust {
    A = ra_on_conflict_select(ctx.user, Value::default());
}

opt_returning(A) ::= .

%action_rust {
    A = Value::default();
}
opt_returning(A) ::= RETURNING target_list(B).
%action_rust {
    A = B;
}

/* -- UPDATE -------------------------------------------------------- */

update_stmt(A) ::= UPDATE IDENT(T) SET assignment_list(S)
                    opt_update_from(F) opt_where(W) opt_returning(R).

%action_rust {
    A = ra_update(ctx.user, T.text(), S, W, F, R);
}
update_stmt(A) ::= UPDATE IDENT(T) AS IDENT SET assignment_list(S)
                    opt_update_from(F) opt_where(W) opt_returning(R).

%action_rust {
    A = ra_update(ctx.user, T.text(), S, W, F, R);
}

assignment_list(A) ::= assignment(B).

%action_rust {
    A = ra_list_push(ctx.user, ra_list_new(ctx.user), B);
}
assignment_list(A) ::= assignment_list(L) COMMA assignment(B).

%action_rust {
    A = ra_list_push(ctx.user, L, B);
}

assignment(A) ::= IDENT(C) EQ expr(V).

%action_rust {
    A = ra_assignment(ctx.user, C.text(), V);
}

opt_update_from(A) ::= .

%action_rust {
    A = Value::default();
}
opt_update_from(A) ::= FROM from_list(B).
%action_rust {
    A = B;
}

