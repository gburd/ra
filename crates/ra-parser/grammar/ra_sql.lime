    A = ra_func(ctx.user, B.text(), l);
}

/* -- FILTER clause on aggregates ----------------------------------- */
/* Rewrite at parse time: COUNT(*) FILTER (WHERE x > 10) →
 *   COUNT(CASE WHEN x > 10 THEN 1 ELSE NULL END)
 * SUM(y) FILTER (WHERE cond) →
 *   SUM(CASE WHEN cond THEN y ELSE NULL END)
 *
 * We use expr_list for the args to avoid shift/reduce conflicts with
 * the general function call rule. ra_filter_agg does the CASE rewrite. */

expr(A) ::= IDENT(B) LPAREN expr_list(C) RPAREN FILTER LPAREN WHERE expr(D) RPAREN.

%action_rust {
    A = ra_filter_agg(ctx.user, B.text(), C, D);
}

expr(A) ::= IDENT(B) LPAREN STAR RPAREN FILTER LPAREN WHERE expr(C) RPAREN.

%action_rust {
    /* COUNT(*) FILTER (WHERE cond) → COUNT(CASE WHEN cond THEN 1 ELSE Value::default() END) */
    let mut when_list = ra_list_new(ctx.user);
    when_list = ra_list_push(ctx.user, when_list, C); /* condition */
    when_list = ra_list_push(ctx.user, when_list, ra_const_int(ctx.user, 1)); /* THEN 1 */
    let mut case_expr = ra_case(ctx.user, Value::default(), when_list, ra_const_null(ctx.user));
    let mut new_args = ra_list_new(ctx.user);
    new_args = ra_list_push(ctx.user, new_args, case_expr);
    A = ra_func(ctx.user, B.text(), new_args);
}

expr(A) ::= IDENT(B) LPAREN DISTINCT expr(C) RPAREN FILTER LPAREN WHERE expr(D) RPAREN.

%action_rust {
    /* agg(DISTINCT x) FILTER (WHERE cond) → agg(DISTINCT CASE WHEN cond THEN x ELSE Value::default() END) */
    let mut when_list = ra_list_new(ctx.user);
    when_list = ra_list_push(ctx.user, when_list, D);
    when_list = ra_list_push(ctx.user, when_list, C);
    let mut case_expr = ra_case(ctx.user, Value::default(), when_list, ra_const_null(ctx.user));
    let mut darg = ra_list_new(ctx.user);
    darg = ra_list_push(ctx.user, darg, case_expr);
    let mut marker = ra_func(ctx.user, "__distinct", darg);
    let mut new_args = ra_list_new(ctx.user);
    new_args = ra_list_push(ctx.user, new_args, marker);
    A = ra_func(ctx.user, B.text(), new_args);
}

/* -- Aggregate DISTINCT: COUNT(DISTINCT col) etc. ------------------ */

expr(A) ::= IDENT(B) LPAREN DISTINCT expr(C) RPAREN.

%action_rust {
    /* Wrap the argument in a __distinct marker so the plan builder, which
       does not yet emit Aggref.aggdistinct, defers to native PG instead of
       silently building a non-DISTINCT aggregate (a wrong result). */
    let mut darg = ra_list_new(ctx.user);
    darg = ra_list_push(ctx.user, darg, C);
    let mut marker = ra_func(ctx.user, "__distinct", darg);
    let mut args = ra_list_new(ctx.user);
    args = ra_list_push(ctx.user, args, marker);
    A = ra_func(ctx.user, B.text(), args);
}

/* -- WITHIN GROUP (ordered-set aggregates) ------------------------- */
/* e.g. PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY salary) */

expr(A) ::= IDENT(B) LPAREN expr_list(C) RPAREN WITHIN GROUP LPAREN ORDER BY sort_list(D) RPAREN.

%action_rust {
    let _ = &D;
    A = ra_func(ctx.user, B.text(), C);
}

/* -- Window function ----------------------------------------------- */
/* func(args) OVER (opt_partition opt_order)
 * The __window_ prefix marks this as a window expression so the
 * post-parse transformer can detect and promote it to Window nodes. */

expr(A) ::= IDENT(B) LPAREN expr_list(C) RPAREN OVER LPAREN
             opt_partition(D) opt_window_order(E) opt_window_frame(F) RPAREN.

%action_rust {
    A = ra_window_marker_full(ctx.user, B.text(), C, D, E, F.int_val);
}

expr(A) ::= IDENT(B) LPAREN STAR RPAREN OVER LPAREN
             opt_partition(C) opt_window_order(D) opt_window_frame(E) RPAREN.

%action_rust {
    let mut l = ra_list_new(ctx.user);
    l = ra_list_push(ctx.user, l, ra_column(ctx.user, "*"));
    A = ra_window_marker_full(ctx.user, B.text(), l, C, D, E.int_val);
}

expr(A) ::= IDENT(B) LPAREN RPAREN OVER LPAREN
             opt_partition(C) opt_window_order(D) opt_window_frame(E) RPAREN.

%action_rust {
    A = ra_window_marker_full(ctx.user, B.text(), ra_list_new(ctx.user), C, D, E.int_val);
}

/* Named window reference: func() OVER w — treated as empty window spec */
expr(A) ::= IDENT(B) LPAREN expr_list(C) RPAREN OVER IDENT.

%action_rust {
    A = ra_window_marker_full(ctx.user, B.text(), C, Value::default(), Value::default(), 0);
}
expr(A) ::= IDENT(B) LPAREN STAR RPAREN OVER IDENT.

%action_rust {
    let mut l = ra_list_new(ctx.user);
    l = ra_list_push(ctx.user, l, ra_column(ctx.user, "*"));
    A = ra_window_marker_full(ctx.user, B.text(), l, Value::default(), Value::default(), 0);
}
expr(A) ::= IDENT(B) LPAREN RPAREN OVER IDENT.

%action_rust {
    A = ra_window_marker_full(ctx.user, B.text(), ra_list_new(ctx.user), Value::default(), Value::default(), 0);
}

opt_partition(A) ::= PARTITION BY expr_list(B).
%action_rust {
    A = B;
}
opt_partition(A) ::= .

%action_rust {
    A = Value::default();
}

opt_window_order(A) ::= ORDER BY sort_list(B).
%action_rust {
    A = B;
}
opt_window_order(A) ::= .

%action_rust {
    A = Value::default();
}

/* Window frame clause: ROWS/RANGE BETWEEN ... AND ... */
opt_window_frame(A) ::= IDENT BETWEEN frame_bound(B) AND frame_bound(C).

%action_rust {
    /* ROWS/RANGE BETWEEN start AND end — flag presence so the optimizer can
     * defer (frame semantics are not built directly). */
    A.int_val = 1;  A.location = 0; A.length = 0; A.float_val = 0.0;
    let _ = &B; let _ = &C;
}
opt_window_frame(A) ::= .

%action_rust {
    A.int_val = 0;  A.location = 0; A.length = 0; A.float_val = 0.0;
}

/* Frame bounds: UNBOUNDED PRECEDING, CURRENT ROW, expr PRECEDING/FOLLOWING */
frame_bound(A) ::= IDENT IDENT.

%action_rust {
    /* UNBOUNDED PRECEDING, UNBOUNDED FOLLOWING, CURRENT ROW */
    A = Value::default();
}
frame_bound(A) ::= expr(B) IDENT.

%action_rust {
    /* N.clone() PRECEDING, N.clone() FOLLOWING */
    A = B;
}

/* -- TRIM special syntax: TRIM(BOTH/LEADING/TRAILING 'chars' FROM expr) --- */
/* This handles SQL's special TRIM syntax that uses FROM as a keyword.
 * The direction identifier (BOTH/LEADING/TRAILING) and the trim character
 * string are discarded; only the source expression is kept.
 * This rule creates a shift-reduce conflict with the IDENT SCONST typed
 * literal rule: both begin with IDENT SCONST. Lime resolves by SHIFT, which
 * picks up the FROM and creates a TRIM call. build.rs tolerates this. */
expr(A) ::= IDENT(B) LPAREN IDENT SCONST FROM expr(C) RPAREN.

%action_rust {
    /* TRIM(BOTH/LEADING/TRAILING 'chars' FROM col) — keep the source expr */
    let mut args = ra_list_new(ctx.user);
    args = ra_list_push(ctx.user, args, C);
    A = ra_func(ctx.user, B.text(), args);
}

/* -- Typed string literals: DATE '...', INTERVAL '...', etc. ------- */
/* When an identifier is immediately followed by a string constant it is
 * treated as a type-qualified literal (DATE '2024-01-01', INTERVAL '1 hour',
 * TIMESTAMP '...', etc.).  The type name is discarded; the string value is
 * returned as a Const::String.
 *
 * This rule creates a shift-reduce conflict: when the parser has just
 * seen an IDENT and the lookahead is SCONST, it must choose between
 * reducing IDENT to expr (column reference) or shifting SCONST.  Lime
 * resolves the conflict by preferring SHIFT, so IDENT SCONST becomes a
 * typed literal.  build.rs tolerates this known resolved conflict. */
expr(A) ::= IDENT SCONST(B).

%action_rust {
    A = ra_const_str(ctx.user, B.text());
}

/* -- EXTRACT function ---------------------------------------------- */
/* EXTRACT(field FROM expr) — encoded as __extract_<field>(expr). */

expr(A) ::= EXTRACT LPAREN IDENT(F) FROM expr(E) RPAREN.

%action_rust {
    let mut l = ra_list_new(ctx.user);
    l = ra_list_push(ctx.user, l, E);
    A = ra_func(ctx.user, "__extract", l);
    let _ = &F;
}

/* -- SUBSTRING function -------------------------------------------- */
/* SQL standard: SUBSTRING(str FROM start FOR length) */
/* SUBSTRING is an IDENT, not a keyword, so it works as a regular function too */
/* FOR is also an IDENT */
expr(A) ::= IDENT LPAREN expr(S) FROM expr(F) IDENT expr(L) RPAREN.

%action_rust {
    /* Match any function with FROM...FOR pattern, but primarily for SUBSTRING */
    let mut args = ra_list_new(ctx.user);
    args = ra_list_push(ctx.user, args, S);
    args = ra_list_push(ctx.user, args, F);
    args = ra_list_push(ctx.user, args, L);
    A = ra_func(ctx.user, "substring", args);
}

/* -- ARRAY literal ------------------------------------------------- */

expr(A) ::= ARRAY LBRACKET expr_list(B) RBRACKET.

%action_rust {
    A = ra_array(ctx.user, B);
}
expr(A) ::= ARRAY LBRACKET RBRACKET.

%action_rust {
    A = ra_array(ctx.user, ra_list_new(ctx.user));
}

/* -- Array subscript: expr[index] ---------------------------------- */

expr(A) ::= expr(B) LBRACKET expr(C) RBRACKET. [LBRACKET]

%action_rust {
    A = ra_array_index(ctx.user, B, C);
}

/* -- Parameter placeholder ----------------------------------------- */

expr(A) ::= PLACEHOLDER.

%action_rust {
    A = ra_const_null(ctx.user); /* placeholder maps to Value::default() for now */
}

/* -- Regex match operator (~) -------------------------------------- */

expr(A) ::= expr(B) TILDE expr(C). [TILDE]

%action_rust {
    let mut args = ra_list_new(ctx.user);
    args = ra_list_push(ctx.user, args, B);
    args = ra_list_push(ctx.user, args, C);
    A = ra_func(ctx.user, "__regex_match", args);
}

/* -- Parenthesized expression -------------------------------------- */

expr(A) ::= LPAREN expr(B) RPAREN.
%action_rust {
    A = B;
}

/* -- Row constructor (tuple) --------------------------------------- */
/* Multi-column tuple: (col1, col2, ...) for use with IN, comparisons */

expr(A) ::= LPAREN expr_list(B) COMMA expr(C) RPAREN.

%action_rust {
    /* Create a tuple/row constructor with 2+ elements */
    let mut args = B.clone(); /* B.clone() is already a list */
    args = ra_list_push(ctx.user, args, C);
    A = ra_func(ctx.user, "__row_constructor", args);
}

/* ================================================================== */
/* Expression list                                                     */
/* ================================================================== */

expr_list(A) ::= expr(B).

%action_rust {
    let mut l = ra_list_new(ctx.user);
    A = ra_list_push(ctx.user, l, B);
}
expr_list(A) ::= expr_list(B) COMMA expr(C).

%action_rust {
    A = ra_list_push(ctx.user, B, C);
}
