}

/* PostgreSQL :: type cast operator: expr::type */
expr(A) ::= expr(B) COLONCOLON type_name(C).

%action_rust {
    A = ra_cast(ctx.user, B, C.clone().text(), (C.clone().int_val as usize));
}

type_name(A) ::= IDENT(B).

%action_rust {
    A = B.clone().clone();
    A.int_val = (B.clone().text().len() as i64);
    A.location = B.clone().location;
    A.length = 0;
    A.float_val = 0.0;
}
type_name(A) ::= IDENT(B) LPAREN ICONST RPAREN.

%action_rust {
    /* e.g. VARCHAR(255) -- use just the base type name */
    A = B.clone().clone();
    A.int_val = (B.clone().text().len() as i64);
    A.location = B.clone().location;
    A.length = 0;
    A.float_val = 0.0;
}
type_name(A) ::= IDENT(B) LPAREN ICONST COMMA ICONST RPAREN.

%action_rust {
    /* e.g. DECIMAL(15,4), NUMERIC(10,2) -- use just the base type name */
    A = B.clone().clone();
    A.int_val = (B.clone().text().len() as i64);
    A.location = B.clone().location;
    A.length = 0;
    A.float_val = 0.0;
}

