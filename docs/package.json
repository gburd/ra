    "build:wasm": "./build-wasm.sh",
    "build:docs": "vitepress build",
    "validate": "./scripts/validate-docs.sh",
    "preview": "vitepress preview",
    "ci": "npm run validate && npm run build:docs"
  },
  "keywords": [],
