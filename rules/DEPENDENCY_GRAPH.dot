    distributed_distributed_sort [label="distributed-sort\n(4)", URL="./rules/distributed/"];
    distributed_distributed_transactions [label="distributed-transactions\n(2)", URL="./rules/distributed/"];
    distributed_exchange_placement [label="exchange-placement\n(5)", URL="./rules/distributed/"];
    distributed_join_algorithms [label="join-algorithms\n(1)", URL="./rules/distributed/"];
    distributed_locality_optimization [label="locality-optimization\n(4)", URL="./rules/distributed/"];
    distributed_partial_aggregation [label="partial-aggregation\n(5)", URL="./rules/distributed/"];
    distributed_partition_pruning [label="partition-pruning\n(5)", URL="./rules/distributed/"];
    distributed_stage_planning [label="stage-planning\n(4)", URL="./rules/distributed/"];
