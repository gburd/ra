digraph rule_dependencies {
  rankdir=LR;
  fontname="Helvetica,Arial,sans-serif";
  node [shape=box, style="filled,rounded", fillcolor=lightyellow,
        fontname="Helvetica,Arial,sans-serif", fontsize=11,
        target="_top"];
  edge [color="#555555", penwidth=1.5, arrowsize=0.8,
        fontname="Helvetica,Arial,sans-serif", fontsize=9];

  subgraph cluster_cost_models {
    label="cost-models (36 rules)";
    style="filled,rounded";
    fillcolor="wheat";
    color="#d4a574";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    cost_models_general [label="general\n(25)", URL="./rules/cost-models/"];
    cost_models_system_r [label="system-r\n(11)", URL="./rules/cost-models/"];
  }

  subgraph cluster_database_specific {
    label="database-specific (357 rules)";
    style="filled,rounded";
    fillcolor="lavender";
    color="#9999cc";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    database_specific_calcite [label="calcite\n(47)", URL="./rules/database-specific/"];
    database_specific_clickhouse [label="clickhouse\n(37)", URL="./rules/database-specific/"];
    database_specific_cockroachdb [label="cockroachdb\n(19)", URL="./rules/database-specific/"];
    database_specific_datafusion [label="datafusion\n(20)", URL="./rules/database-specific/"];
