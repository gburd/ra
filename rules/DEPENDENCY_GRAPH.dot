  // logical -> physical [plan selection]
  // physical -> distributed [distribution]
  // physical -> hardware [hw-aware]
  // cost_models -> physical [cost estimation]
  // cost_models -> logical [cost-based rewrites]
  // experimental -> logical [new rewrites]
