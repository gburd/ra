    database_specific_drill [label="drill\n(4)", URL="./rules/database-specific/"];
    database_specific_duckdb [label="duckdb\n(2)", URL="./rules/database-specific/"];
    database_specific_flink [label="flink\n(7)", URL="./rules/database-specific/"];
    database_specific_greenplum [label="greenplum\n(2)", URL="./rules/database-specific/"];
    database_specific_hyper [label="hyper\n(3)", URL="./rules/database-specific/"];
    database_specific_impala [label="impala\n(4)", URL="./rules/database-specific/"];
    database_specific_materialize [label="materialize\n(21)", URL="./rules/database-specific/"];
    database_specific_monetdb [label="monetdb\n(28)", URL="./rules/database-specific/"];
    database_specific_mongodb [label="mongodb\n(19)", URL="./rules/database-specific/"];
    database_specific_mssql [label="mssql\n(20)", URL="./rules/database-specific/"];
    database_specific_mysql [label="mysql\n(25)", URL="./rules/database-specific/"];
    database_specific_neo4j [label="neo4j\n(17)", URL="./rules/database-specific/"];
    database_specific_oracle [label="oracle\n(20)", URL="./rules/database-specific/"];
    database_specific_postgresql [label="postgresql\n(2)", URL="./rules/database-specific/"];
    database_specific_presto [label="presto\n(3)", URL="./rules/database-specific/"];
    database_specific_sqlite [label="sqlite\n(2)", URL="./rules/database-specific/"];
    database_specific_tidb [label="tidb\n(19)", URL="./rules/database-specific/"];
    database_specific_timescaledb [label="timescaledb\n(3)", URL="./rules/database-specific/"];
    database_specific_trino [label="trino\n(6)", URL="./rules/database-specific/"];
    database_specific_voltdb [label="voltdb\n(3)", URL="./rules/database-specific/"];
  }

  subgraph cluster_distributed {
    label="distributed (58 rules)";
    style="filled,rounded";
    fillcolor="lightsalmon";
    color="#e08060";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    distributed_aggregation_strategies [label="aggregation-strategies\n(1)", URL="./rules/distributed/"];
    distributed_colocation [label="colocation\n(6)", URL="./rules/distributed/"];
    distributed_coprocessor_pushdown [label="coprocessor-pushdown\n(2)", URL="./rules/distributed/"];
    distributed_data_movement [label="data-movement\n(6)", URL="./rules/distributed/"];
