    execution_models_approximate [label="approximate\n(1)", URL="./rules/execution-models/"];
    execution_models_column_at_a_time [label="column-at-a-time\n(3)", URL="./rules/execution-models/"];
    execution_models_compilation [label="compilation\n(1)", URL="./rules/execution-models/"];
    execution_models_differential [label="differential\n(8)", URL="./rules/execution-models/"];
    execution_models_general [label="general\n(62)", URL="./rules/execution-models/"];
    execution_models_hardware_accel [label="hardware-accel\n(2)", URL="./rules/execution-models/"];
    execution_models_ml_guided [label="ml-guided\n(3)", URL="./rules/execution-models/"];
    execution_models_morsel_driven [label="morsel-driven\n(3)", URL="./rules/execution-models/"];
    execution_models_parallelization [label="parallelization\n(1)", URL="./rules/execution-models/"];
    execution_models_push_based [label="push-based\n(2)", URL="./rules/execution-models/"];
    execution_models_vectorized [label="vectorized\n(3)", URL="./rules/execution-models/"];
  }

  subgraph cluster_experimental {
    label="experimental (46 rules)";
    style="filled,rounded";
    fillcolor="#ffffdd";
    color="#cccc88";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    experimental_adaptive [label="adaptive\n(12)", URL="./rules/experimental/"];
    experimental_aggregation_strategies [label="aggregation-strategies\n(1)", URL="./rules/experimental/"];
    experimental_approximate [label="approximate\n(3)", URL="./rules/experimental/"];
    experimental_compilation [label="compilation\n(2)", URL="./rules/experimental/"];
    experimental_hardware_accel [label="hardware-accel\n(2)", URL="./rules/experimental/"];
    experimental_ml_guided [label="ml-guided\n(9)", URL="./rules/experimental/"];
    experimental_semantic [label="semantic\n(7)", URL="./rules/experimental/"];
    experimental_wcoj [label="wcoj\n(10)", URL="./rules/experimental/"];
  }

  subgraph cluster_hardware {
    label="hardware (22 rules)";
    style="filled,rounded";
    fillcolor="lightcyan";
    color="#80b0c0";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    hardware_accelerator [label="accelerator\n(5)", URL="./rules/hardware/"];
    hardware_data_placement [label="data-placement\n(4)", URL="./rules/hardware/"];
    hardware_fpga [label="fpga\n(4)", URL="./rules/hardware/"];
    hardware_gpu [label="gpu\n(8)", URL="./rules/hardware/"];
  }

  subgraph cluster_logical {
    label="logical (210 rules)";
    style="filled,rounded";
    fillcolor="lightblue";
    color="#6699cc";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    logical_aggregate_pushdown [label="aggregate-pushdown\n(22)", URL="./rules/logical/"];
    logical_cte_optimization [label="cte-optimization\n(5)", URL="./rules/logical/"];
    logical_distinct_elimination [label="distinct-elimination\n(5)", URL="./rules/logical/"];
    logical_expression_simplification [label="expression-simplification\n(10)", URL="./rules/logical/"];
    logical_function_optimization [label="function-optimization\n(58)", URL="./rules/logical/"];
    logical_join_elimination [label="join-elimination\n(19)", URL="./rules/logical/"];
    logical_join_reordering [label="join-reordering\n(9)", URL="./rules/logical/"];
    logical_limit_pushdown [label="limit-pushdown\n(12)", URL="./rules/logical/"];
    logical_predicate_pushdown [label="predicate-pushdown\n(17)", URL="./rules/logical/"];
    logical_projection_pushdown [label="projection-pushdown\n(7)", URL="./rules/logical/"];
    logical_semantic_rewriting [label="semantic-rewriting\n(8)", URL="./rules/logical/"];
    logical_set_operations [label="set-operations\n(10)", URL="./rules/logical/"];
    logical_sideways_information_passing [label="sideways-information-passing\n(3)", URL="./rules/logical/"];
    logical_subquery_unnesting [label="subquery-unnesting\n(17)", URL="./rules/logical/"];
    logical_timeseries [label="timeseries\n(1)", URL="./rules/logical/"];
    logical_view_rewriting [label="view-rewriting\n(2)", URL="./rules/logical/"];
    logical_window_pushdown [label="window-pushdown\n(4)", URL="./rules/logical/"];
  }

  subgraph cluster_multi_model {
    label="multi-model (30 rules)";
    style="filled,rounded";
    fillcolor="honeydew";
    color="#88bb88";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    multi_model_document [label="document\n(10)", URL="./rules/multi-model/"];
    multi_model_graph [label="graph\n(10)", URL="./rules/multi-model/"];
    multi_model_timeseries [label="timeseries\n(10)", URL="./rules/multi-model/"];
  }

  subgraph cluster_physical {
    label="physical (109 rules)";
    style="filled,rounded";
    fillcolor="lightgreen";
    color="#66aa66";
    fontname="Helvetica,Arial,sans-serif";
    fontsize=13;
    node [fillcolor=white];
    physical_access_path_selection [label="access-path-selection\n(4)", URL="./rules/physical/"];
    physical_aggregation_strategies [label="aggregation-strategies\n(16)", URL="./rules/physical/"];
    physical_index_selection [label="index-selection\n(36)", URL="./rules/physical/"];
    physical_join_algorithms [label="join-algorithms\n(18)", URL="./rules/physical/"];
    physical_materialization [label="materialization\n(13)", URL="./rules/physical/"];
    physical_optimizer_framework [label="optimizer-framework\n(5)", URL="./rules/physical/"];
    physical_parallelization [label="parallelization\n(16)", URL="./rules/physical/"];
  }

  // Dependency edges between categories
  logical_join_reordering -> physical_join_algorithms [label="plan\nselection", style=dashed];
  logical_predicate_pushdown -> physical_access_path_selection [label="plan\nselection", style=dashed];
  physical_parallelization -> distributed_exchange_placement [label="distribution", style=dashed];
  physical_join_algorithms -> distributed_distributed_joins [label="distribution", style=dashed];
  physical_access_path_selection -> hardware_gpu [label="hw-aware", style=dashed];
  physical_materialization -> hardware_data_placement [label="hw-aware", style=dashed];
  cost_models_general -> physical_index_selection [label="cost\nestimation", style=dashed];
  cost_models_system_r -> physical_join_algorithms [label="cost\nestimation", style=dashed];
  cost_models_general -> logical_join_reordering [label="cost-based\nrewrites", style=dashed];
  experimental_adaptive -> logical_predicate_pushdown [label="new\nrewrites", style=dashed];
  experimental_wcoj -> physical_join_algorithms [label="new\noperators", style=dashed];
  multi_model_document -> logical_expression_simplification [label="model-specific\nrewrites", style=dashed];
  multi_model_graph -> logical_join_reordering [label="model-specific\nrewrites", style=dashed];
}